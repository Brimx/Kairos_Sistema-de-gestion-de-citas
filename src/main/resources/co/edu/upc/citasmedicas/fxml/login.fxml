<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15.0" prefWidth="420.0" prefHeight="380.0"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="co.edu.upc.citasmedicas.controller.LoginController"
      stylesheets="@../css/styles.css" styleClass="login-container">
    <padding>
        <Insets top="24.0" right="24.0" bottom="24.0" left="24.0" />
    </padding>

    <Label text="Iniciar Sesion" styleClass="title-label"/>
    <TextField fx:id="emailField" promptText="Email" styleClass="input-field"/>
    <HBox spacing="0" maxWidth="Infinity" styleClass="password-wrapper">
        <StackPane HBox.hgrow="ALWAYS" maxWidth="Infinity">
            <PasswordField fx:id="passwordField" promptText="Contrasena" styleClass="input-field-pwd" maxWidth="Infinity"/>
            <TextField fx:id="passwordVisibleField" promptText="Contrasena" styleClass="input-field-pwd" visible="false" managed="false" maxWidth="Infinity"/>
        </StackPane>
        <Button fx:id="togglePasswordBtn" text="👁" styleClass="toggle-password-btn" onAction="#togglePasswordVisibility"/>
    </HBox>
    <Button text="Ingresar" onAction="#handleLogin" styleClass="login-button"/>
    <Button text="Crear cuenta (Registro)" onAction="#handleIrRegistro" styleClass="secondary-button"/>
    <Label fx:id="errorLabel" wrapText="true" maxWidth="300.0" styleClass="helper-label"/>
</VBox>
