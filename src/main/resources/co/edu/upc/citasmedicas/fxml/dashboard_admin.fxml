<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.upc.citasmedicas.controller.DashboardAdminController"
            styleClass="bg-default" prefWidth="960" prefHeight="680"
            stylesheets="@../css/styles.css">

    <top>
        <HBox styleClass="header-bar">
            <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
            <Label fx:id="lblBienvenida" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblContador" styleClass="header-subtitle"/>
            <Label text="ADMINISTRADOR" styleClass="header-role"/>
            <Button text="Horarios" onAction="#handleGestionarHorarios" styleClass="btn-ghost"/>
            <Button text="Bloqueos" onAction="#handleGestionarBloqueos" styleClass="btn-ghost"/>
            <Button text="Cerrar Sesion" onAction="#handleCerrarSesion" styleClass="btn-logout"/>
        </HBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" styleClass="panel-padding">

            <Tab text="Pacientes">
                <VBox spacing="12">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="Gestion de Pacientes" styleClass="section-title"/>

                    <TextField fx:id="searchPacientes" promptText="Buscar pacientes..." styleClass="input-small" maxWidth="Infinity"/>

                    <TableView fx:id="tablaPacientes" VBox.vgrow="ALWAYS" prefHeight="280">
                        <columns>
                            <TableColumn fx:id="colPacNombre" text="Nombre"     prefWidth="180"/>
                            <TableColumn fx:id="colPacEmail"  text="Email"      prefWidth="180"/>
                            <TableColumn fx:id="colPacTipoDoc" text="Tipo Doc" prefWidth="80"/>
                            <TableColumn fx:id="colPacDoc"    text="Documento"  prefWidth="110"/>
                            <TableColumn fx:id="colPacTel"    text="Telefono"   prefWidth="110"/>
                            <TableColumn fx:id="colPacEps"    text="EPS"        prefWidth="120"/>
                        </columns>
                    </TableView>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button text="Modificar paciente" onAction="#handleModificarPaciente" styleClass="btn-primary" prefHeight="34"/>
                        <Button text="Desactivar" onAction="#handleDesactivarPaciente" styleClass="btn-danger" prefHeight="34"/>
                    </HBox>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button text="+ Nuevo paciente" onAction="#handleNuevoPaciente" styleClass="btn-success" prefHeight="34"/>
                    </HBox>
                    <Label fx:id="lblMensaje" text="" styleClass="feedback-ok"/>
                </VBox>
            </Tab>

            <Tab text="Medicos">
                <VBox spacing="12">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="Medicos registrados" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="+ Registrar nuevo medico"
                                onAction="#irARegistroMedico" styleClass="btn-primary"/>
                    </HBox>
                    <TextField fx:id="searchMedicos" promptText="Buscar medicos..." styleClass="input-small" maxWidth="Infinity"/>
                    <TableView fx:id="tablaMedicos" VBox.vgrow="ALWAYS" prefHeight="280">
                        <columns>
                            <TableColumn fx:id="colMedNombre" text="Nombre"       prefWidth="160"/>
                            <TableColumn fx:id="colMedEmail"  text="Email"        prefWidth="160"/>
                            <TableColumn fx:id="colMedEsp"    text="Especialidad" prefWidth="140"/>
                            <TableColumn fx:id="colMedRegistro" text="Registro"  prefWidth="100"/>
                            <TableColumn fx:id="colMedTel"    text="Telefono"     prefWidth="110"/>
                            <TableColumn fx:id="colMedCons"   text="Consultorio"  prefWidth="110"/>
                        </columns>
                    </TableView>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button text="Modificar medico" onAction="#handleModificarMedico" styleClass="btn-primary" prefHeight="34"/>
                        <Button text="Eliminar medico" onAction="#handleEliminarMedico" styleClass="btn-danger" prefHeight="34"/>
                    </HBox>
                    <Label fx:id="lblMensajeMedicos" text="" styleClass="feedback-ok"/>
                </VBox>
            </Tab>

            <Tab text="Todas las citas">
                <VBox spacing="12">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="Citas del sistema" styleClass="section-title"/>
                    <TextField fx:id="searchCitas" promptText="Buscar citas..." styleClass="input-small" maxWidth="Infinity"/>
                    <TableView fx:id="tablaCitas" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colCitaPac"     text="Paciente"  prefWidth="150"/>
                            <TableColumn fx:id="colCitaMed"     text="Medico"    prefWidth="150"/>
                            <TableColumn fx:id="colCitaServicio" text="Servicio" prefWidth="140"/>
                            <TableColumn fx:id="colCitaFecha"   text="Fecha"     prefWidth="100"/>
                            <TableColumn fx:id="colCitaHora"    text="Hora"      prefWidth="70"/>
                            <TableColumn fx:id="colCitaTipo"    text="Tipo"      prefWidth="90"/>
                            <TableColumn fx:id="colCitaEstado"  text="Estado"   prefWidth="100"/>
                            <TableColumn fx:id="colCitaMotivo"  text="Motivo"   prefWidth="150"/>
                        </columns>
                    </TableView>
                    <HBox spacing="10">
                        <Button text="Agregar cita" onAction="#handleAgregarCita" styleClass="btn-primary"/>
                        <Button text="Modificar cita" onAction="#handleModificarCita" styleClass="btn-primary"/>
                        <Button text="Confirmar cita" onAction="#handleConfirmarCita" styleClass="btn-success"/>
                        <Button text="Cancelar cita" onAction="#handleCancelarCita" styleClass="btn-danger"/>
                        <Button text="No Asistio" onAction="#handleNoAsistio" styleClass="btn-danger"/>
                    </HBox>
                    <Label fx:id="lblMensajeCitas" text="" styleClass="feedback-ok"/>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>
