<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.upc.citasmedicas.controller.DashboardAdminController"
            styleClass="bg-default" prefWidth="960" prefHeight="680"
            stylesheets="@../css/styles.css">

    <top>
        <HBox styleClass="header-bar">
            <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
            <Label fx:id="lblBienvenida" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="ADMINISTRADOR" styleClass="header-role"/>
            <Button text="Cerrar Sesion" onAction="#handleCerrarSesion" styleClass="btn-logout"/>
        </HBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" styleClass="panel-padding">

            <Tab text="Pacientes">
                <VBox spacing="12">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="Gestion de Pacientes" styleClass="section-title"/>

                    <TableView fx:id="tablaPacientes" VBox.vgrow="ALWAYS" prefHeight="300">
                        <columns>
                            <TableColumn fx:id="colPacNombre" text="Nombre"   prefWidth="200"/>
                            <TableColumn fx:id="colPacEmail"  text="Email"    prefWidth="220"/>
                            <TableColumn fx:id="colPacDoc"    text="Documento" prefWidth="130"/>
                            <TableColumn fx:id="colPacTel"    text="Telefono" prefWidth="130"/>
                        </columns>
                    </TableView>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="txtEditNombre" promptText="Nombre" prefWidth="200" styleClass="input-small"/>
                        <TextField fx:id="txtEditTel"    promptText="Telefono" prefWidth="150" styleClass="input-small"/>
                        <Button text="Guardar cambios" onAction="#handleGuardarPaciente" styleClass="btn-primary" prefHeight="34"/>
                        <Button text="Desactivar paciente" onAction="#handleDesactivarPaciente" styleClass="btn-danger" prefHeight="34"/>
                    </HBox>
                    <Label fx:id="lblMensaje" text="" styleClass="feedback-ok"/>
                </VBox>
            </Tab>

            <Tab text="Medicos">
                <VBox spacing="12">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="Medicos registrados" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="+ Registrar nuevo medico"
                                onAction="#irARegistroMedico" styleClass="btn-primary"/>
                    </HBox>
                    <TableView fx:id="tablaMedicos" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colMedNombre" text="Nombre"       prefWidth="220"/>
                            <TableColumn fx:id="colMedEmail"  text="Email"        prefWidth="230"/>
                            <TableColumn fx:id="colMedEsp"    text="Especialidad" prefWidth="200"/>
                        </columns>
                    </TableView>
                    <Label fx:id="lblMensajeMedicos" text="" styleClass="feedback-ok"/>
                </VBox>
            </Tab>

            <Tab text="Todas las citas">
                <VBox spacing="12">
                    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                    <Label text="Citas del sistema" styleClass="section-title"/>
                    <TableView fx:id="tablaCitas" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colCitaPac"   text="Paciente"  prefWidth="170"/>
                            <TableColumn fx:id="colCitaMed"   text="Medico"    prefWidth="170"/>
                            <TableColumn fx:id="colCitaFecha" text="Fecha"     prefWidth="110"/>
                            <TableColumn fx:id="colCitaHora"  text="Hora"      prefWidth="80"/>
                            <TableColumn fx:id="colCitaEstado" text="Estado"   prefWidth="110"/>
                        </columns>
                    </TableView>
                    <HBox spacing="10">
                        <Button text="Confirmar cita" onAction="#handleConfirmarCita" styleClass="btn-success"/>
                        <Button text="Cancelar cita" onAction="#handleCancelarCita" styleClass="btn-danger"/>
                    </HBox>
                    <Label fx:id="lblMensajeCitas" text="" styleClass="feedback-ok"/>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>
