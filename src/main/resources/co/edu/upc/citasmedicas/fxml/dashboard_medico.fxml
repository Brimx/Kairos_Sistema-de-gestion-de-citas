<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.upc.citasmedicas.controller.DashboardMedicoController"
            styleClass="bg-default" prefWidth="1100" prefHeight="580"
            stylesheets="@../css/styles.css">

    <top>
        <HBox styleClass="header-bar">
            <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
            <VBox>
                <Label fx:id="lblBienvenida" styleClass="header-title"/>
                <Label fx:id="lblEspecialidad" styleClass="header-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblContador" styleClass="header-subtitle"/>
            <Button text="Horarios" onAction="#handleGestionarHorarios" styleClass="btn-ghost"/>
            <Button text="Actualizar" onAction="#handleActualizar" styleClass="btn-ghost"/>
            <Button text="Mis datos" onAction="#handleModificarMisDatos" styleClass="btn-ghost"/>
            <Button text="Cerrar Sesion" onAction="#handleCerrarSesion" styleClass="btn-logout"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="12">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

            <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

                <Tab text="Agenda del dia">
                    <VBox spacing="12">
                        <padding><Insets top="12" right="0" bottom="0" left="0"/></padding>
                        <TextField fx:id="searchCitas" promptText="Buscar citas..." styleClass="input-small" maxWidth="Infinity"/>
                        <TableView fx:id="tablaAgenda" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colPaciente"      text="Paciente"     prefWidth="150"/>
                                <TableColumn fx:id="colTipoDocPac"    text="Tipo Doc"     prefWidth="70"/>
                                <TableColumn fx:id="colDocPac"        text="Documento"    prefWidth="100"/>
                                <TableColumn fx:id="colEmailPac"      text="Email"        prefWidth="160"/>
                                <TableColumn fx:id="colDireccionPac"  text="Direccion"    prefWidth="130"/>
                                <TableColumn fx:id="colFecha"         text="Fecha"        prefWidth="90"/>
                                <TableColumn fx:id="colHora"          text="Hora"         prefWidth="65"/>
                                <TableColumn fx:id="colServicio"      text="Servicio"     prefWidth="130"/>
                                <TableColumn fx:id="colTipo"          text="Tipo"         prefWidth="90"/>
                                <TableColumn fx:id="colMotivo"        text="Motivo"       prefWidth="130"/>
                                <TableColumn fx:id="colEstado"        text="Estado"       prefWidth="90"/>
                            </columns>
                        </TableView>
                        <HBox spacing="10">
                            <Button text="Iniciar Consulta" onAction="#handleIniciarConsulta" styleClass="btn-primary" prefHeight="36"/>
                            <Button text="Reprogramar" onAction="#handleReprogramarCita" styleClass="btn-ghost" prefHeight="36"/>
                            <Button text="Atendido" onAction="#handleAtender" styleClass="btn-success" prefHeight="36"/>
                            <Button text="No Asistio" onAction="#handleNoAsistio" styleClass="btn-danger" prefHeight="36"/>
                        </HBox>
                        <Label fx:id="lblMensaje" text="" styleClass="feedback-ok"/>
                    </VBox>
                </Tab>

                <Tab text="Calendario">
                    <VBox fx:id="calendarContainer" spacing="10">
                        <padding><Insets top="8" right="0" bottom="0" left="0"/></padding>
                    </VBox>
                </Tab>

            </TabPane>

        </VBox>
    </center>
</BorderPane>
