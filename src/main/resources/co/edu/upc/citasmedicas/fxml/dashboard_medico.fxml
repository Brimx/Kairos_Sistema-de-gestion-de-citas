<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.upc.citasmedicas.controller.DashboardMedicoController"
            styleClass="bg-default" prefWidth="860" prefHeight="580">

    <top>
        <HBox styleClass="header-bar">
            <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
            <VBox>
                <Label fx:id="lblBienvenida" styleClass="header-title"/>
                <Label fx:id="lblEspecialidad" styleClass="header-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Actualizar" onAction="#handleActualizar" styleClass="btn-ghost"/>
            <Button text="Cerrar Sesion" onAction="#handleCerrarSesion" styleClass="btn-logout"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="12">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

            <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

                <Tab text="Agenda del dia">
                    <VBox spacing="12">
                        <padding><Insets top="12" right="0" bottom="0" left="0"/></padding>
                        <TableView fx:id="tablaAgenda" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colPaciente" text="Paciente"   prefWidth="200"/>
                                <TableColumn fx:id="colFecha"    text="Fecha"      prefWidth="110"/>
                                <TableColumn fx:id="colHora"     text="Hora"       prefWidth="80"/>
                                <TableColumn fx:id="colTipo"     text="Tipo"       prefWidth="100"/>
                                <TableColumn fx:id="colEstado"   text="Estado"     prefWidth="110"/>
                            </columns>
                        </TableView>
                        <HBox spacing="10">
                            <Button text="Marcar como atendido" onAction="#handleAtender" styleClass="btn-success" prefHeight="36"/>
                        </HBox>
                        <Label fx:id="lblMensaje" text="" styleClass="feedback-ok"/>
                    </VBox>
                </Tab>

                <Tab text="Calendario">
                    <VBox fx:id="calendarContainer" spacing="10">
                        <padding><Insets top="8" right="0" bottom="0" left="0"/></padding>
                    </VBox>
                </Tab>

            </TabPane>

        </VBox>
    </center>
</BorderPane>
