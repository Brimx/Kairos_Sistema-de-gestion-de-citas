<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="co.edu.upc.citasmedicas.controller.DashboardPacienteController"
            styleClass="bg-default" prefWidth="960" prefHeight="680">

    <top>
        <HBox styleClass="header-bar">
            <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
            <Label fx:id="lblBienvenida" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="PACIENTE" styleClass="header-role"/>
            <Button text="Cerrar Sesion" onAction="#handleCerrarSesion" styleClass="btn-logout"/>
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.45">

            <ScrollPane fitToWidth="true">
                <VBox spacing="12" styleClass="form-container">
                    <Label text="Agendar nueva cita" styleClass="section-title"/>

                    <Label text="Medico:" styleClass="field-label"/>
                    <ComboBox fx:id="cbMedico" maxWidth="Infinity" promptText="Selecciona medico"/>

                    <Label text="Fecha (AAAA-MM-DD):" styleClass="field-label"/>
                    <TextField fx:id="txtFecha" promptText="2025-06-15" styleClass="input-height" maxWidth="Infinity"/>

                    <Label text="Hora:" styleClass="field-label"/>
                    <ComboBox fx:id="cbHora" maxWidth="Infinity"/>

                    <Label text="Tipo de cita:" styleClass="field-label"/>
                    <ComboBox fx:id="cbTipo" maxWidth="Infinity"/>

                    <Label text="Motivo de consulta:" styleClass="field-label"/>
                    <TextField fx:id="txtMotivo" promptText="Describe tu motivo (opcional)" styleClass="input-height" maxWidth="Infinity"/>

                    <Button text="Agendar cita" onAction="#handleAgendarCita" styleClass="btn-agendar"/>

                    <Label fx:id="lblMensaje" text="" wrapText="true" styleClass="feedback-ok"/>
                </VBox>
            </ScrollPane>

            <VBox spacing="10" styleClass="table-container">
                <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

                    <Tab text="Mis citas">
                        <VBox spacing="10">
                            <padding><Insets top="12" right="0" bottom="0" left="0"/></padding>
                            <TableView fx:id="tablaCitas" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colFecha"  text="Fecha"   prefWidth="100"/>
                                    <TableColumn fx:id="colMedico" text="Medico"  prefWidth="150"/>
                                    <TableColumn fx:id="colHora"   text="Hora"    prefWidth="70"/>
                                    <TableColumn fx:id="colTipo"   text="Tipo"    prefWidth="90"/>
                                    <TableColumn fx:id="colEstado" text="Estado"  prefWidth="100"/>
                                </columns>
                            </TableView>
                            <Button text="Cancelar cita seleccionada"
                                    onAction="#handleCancelarCita" styleClass="btn-danger" maxWidth="Infinity"/>
                        </VBox>
                    </Tab>

                    <Tab text="Calendario">
                        <VBox fx:id="calendarContainer" spacing="10">
                            <padding><Insets top="8" right="0" bottom="0" left="0"/></padding>
                        </VBox>
                    </Tab>

                </TabPane>
            </VBox>

        </SplitPane>
    </center>
</BorderPane>
